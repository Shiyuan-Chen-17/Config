# focus window
lalt - a : yabai -m window --focus west
lalt - s : yabai -m window --focus south
lalt - w : yabai -m window --focus north
lalt - d : yabai -m window --focus east


# swap managed window
lshift + alt - w : yabai -m window --swap north
lshift + alt - s : yabai -m window --swap south
lshift + alt - a : yabai -m window --swap west
lshift + alt - d : yabai -m window --swap east
# move managed window
lshift + cmd - a : yabai -m window --warp west
lshift + cmd - w : yabai -m window --warp north
lshift + cmd - s : yabai -m window --warp south
lshift + cmd - d : yabai -m window --warp east

# increase window size
ralt - a : yabai -m window --resize left:-20:0
ralt - d : yabai -m window --resize right:20:0
ralt - w : yabai -m window --resize top:0:20
ralt - s : yabai -m window --resize bottom:0:20
# decrease window size
shift + ralt - s : yabai -m window --resize bottom:0:-20
shift + ralt - w : yabai -m window --resize top:0:-20
shift + ralt - a : yabai -m window --resize left:20:0
shift + ralt - d : yabai -m window --resize right:-20:0

#Move to new space
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6
alt - 7 : yabai -m space --focus 7
alt - 8 : yabai -m space --focus 8
alt - 9 : yabai -m space --focus 9
#Move window to new space
shift + alt - 1 : yabai -m window --space 1
shift + alt - 2 : yabai -m window --space 2
shift + alt - 3 : yabai -m window --space 3
shift + alt - 4 : yabai -m window --space 4
shift + alt - 5 : yabai -m window --space 5
shift + alt - 6 : yabai -m window --space 6
shift + alt - 7 : yabai -m window --space 7
shift + alt - 8 : yabai -m window --space 8
shift + alt - 9 : yabai -m window --space 9

# Float / Unfloat window
shift + alt - f : \
    yabai -m window --toggle float; \
    yabai -m window --toggle border

shift + alt - t : yabai -m config window_opacity on
shift + alt + ctrl - t : yabai -m config window_opacity off


# balance size of windows
shift + alt - tab : yabai -m space --balance

# toggle window split type
alt - e : yabai -m window --toggle split

# Open common applications
lalt + shift + lctrl - c : osascript -e 'tell application "Google Chrome" to make new window'
lalt + shift + lctrl - f : osascript -e 'tell application "Finder" to make new Finder window'
