export const render = ({ output }) => {
  const [time, dateString, day] = output.split("\n");
  const displayTime = time ? time.trim() : "LOADING";
  const displayDate = dateString ? dateString.toUpperCase() : "";
  const displayDay = day ? day.toUpperCase() : "";

  return (
    <div>
      <div className="time">{displayTime}</div>
      <div className="date">{displayDate}</div>
      <div className="day">- {displayDay} -</div>
    </div>
  );
};
